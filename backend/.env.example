NODE_ENV=development
PORT=5000
# Comma-separated allowed origins. Supports wildcard patterns like https://*.vercel.app
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=8h
DB_HOST=localhost
DB_PORT=3306
DB_NAME=verbena_crm
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
UPLOAD_DIR=uploads
